#!/usr/bin/env bash
# factory — Big Iron
#
# Autonomous AI-native SDLC orchestrator. Give it a codebase and a goal;
# it works through all phases headlessly using graph-grounded decisions.
#
# Usage:
#   factory run <codebase> "<goal>"    Autonomous goal completion (phases 1-6)
#   factory health <codebase>          Health check + risk report (read-only)
#   factory improve <codebase>         Continuous improvement pass (health + refactor)
#
# Examples:
#   factory run ./demo "add discount system to orders"
#   factory health ./demo
#   factory improve ./demo
#
# Requires:
#   SUPERMODEL_API_KEY in env or ~/.hermes/.env
#   hermes CLI installed and configured

set -uo pipefail

FACTORY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS="$FACTORY_DIR/scripts"

BOLD='\033[1m'; DIM='\033[2m'; RED='\033[0;31m'; GREEN='\033[0;32m'
YELLOW='\033[1;33m'; CYAN='\033[0;36m'; RESET='\033[0m'

# ---------------------------------------------------------------------------
# Guards
# ---------------------------------------------------------------------------

require_env() {
  # Load ~/.hermes/.env if SUPERMODEL_API_KEY not already in shell
  if [[ -z "${SUPERMODEL_API_KEY:-}" && -f "$HOME/.hermes/.env" ]]; then
    # shellcheck disable=SC1090
    set -a; source "$HOME/.hermes/.env"; set +a
  fi
  if [[ -z "${SUPERMODEL_API_KEY:-}" ]]; then
    echo -e "${RED}ERROR: SUPERMODEL_API_KEY not set.${RESET}" >&2
    echo "  Add to ~/.hermes/.env or: export SUPERMODEL_API_KEY=smsk_live_..." >&2
    exit 1
  fi
  if ! command -v hermes &>/dev/null; then
    echo -e "${RED}ERROR: hermes not found in PATH.${RESET}" >&2
    echo "  Install: pip install hermes-agent" >&2
    exit 1
  fi
}

require_codebase() {
  local path="$1"
  if [[ ! -d "$path" ]]; then
    echo -e "${RED}ERROR: Codebase not found: $path${RESET}" >&2
    exit 1
  fi
  cd "$path" && pwd
}

banner() {
  echo ""
  echo -e "${BOLD}        _________      ${RESET}"
  echo -e "${BOLD}       /  _____  \\     ${RESET}"
  echo -e "${BOLD}      /___________\\    ${RESET}"
  echo -e "${BOLD}      |  (o)  (o) |    B I G   I R O N${RESET}"
  echo -e "${BOLD}      |     ^     |    ~~~~~~~~~~~~~~~~~${RESET}"
  echo -e "${BOLD}      |   [---]   |    AI-Native SDLC${RESET}"
  echo -e "${BOLD}      |___________|    Ride the graph. Ship clean iron.${RESET}"
  echo -e "${BOLD}      /|         |\\   ${RESET}"
  echo -e "${BOLD}     (_)         (_)  ${RESET}"
  echo ""
}

# ---------------------------------------------------------------------------
# Prompts
# ---------------------------------------------------------------------------

build_run_prompt() {
  local codebase="$1" goal="$2"
  cat <<PROMPT
You are Big Iron — an autonomous AI-native SDLC system backed by the Supermodel
code graph API.

Goal:     $goal
Codebase: $codebase

Work through the SDLC phase pipeline below in order. Do not skip phases.
Do not advance until the current phase gate passes. If a gate fails, diagnose
the violation, fix it, and re-run the gate before proceeding.

Graph-first rule: query the graph before reading any source file. Use the
terminal tool to call graph_gate.sh and supermodel.sh for all graph operations.
Only open a source file when you are about to write to it.

Tools available in terminal:
  $SCRIPTS/graph_gate.sh <phase> $codebase     — pre-built phase gate
  $SCRIPTS/supermodel.sh <endpoint> $codebase  — raw graph query

Important: Supermodel API calls can take up to 20 minutes on large codebases.
The scripts will poll automatically — do NOT kill them early or assume failure
if they are still running. Wait for exit code 0 or 1 before interpreting output.
If a graph call returns 0 nodes/domains, it means the API completed but found
nothing classifiable in that category — not a script failure. Continue with
what data was returned, falling back to file inspection only as a last resort.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 1 — PLANNING  (/planning skill)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Load and follow the planning skill.

- Map the domain structure of the codebase (graph_gate.sh arch $codebase)
- Identify which symbols will change to accomplish the goal
- Compute blast radius for each changed symbol
- Flag cross-domain dependencies the change introduces
- Produce a structured implementation plan with a phase checklist

Print the plan before proceeding to Phase 2.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 2 — ARCHITECTURE REVIEW  (/arch_check skill)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Load and follow the arch_check skill. Load guardrails first.

- Check for circular dependencies in the proposed design path
- Validate domain layering: infrastructure may NOT call application layer
- Check protected interfaces (signature changes affect callers)
- Check coupling thresholds on target modules

Issue verdict: PASS, CONDITIONAL, or FAIL.
Gate: PASS or CONDITIONAL required. If FAIL, revise the plan and recheck.
If CONDITIONAL, record the condition and enforce it during Phase 3.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 3 — CODE GENERATION  (/codegen skill)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Load and follow the codegen skill.

- Fetch exact signatures for all touched symbols from the graph
- Resolve import paths via the dependency graph — do not guess
- Check for existing implementations before writing new ones (fuzzy search)
- Write the code — matching signatures, imports, naming, error-handling style
- Verify every new call resolves to a real symbol in the same changeset

Write leaf symbols first, callers after (topological order).

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 4 — QUALITY GATES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Run: $SCRIPTS/graph_gate.sh quality $codebase

Gate: must PASS. If FAIL:
  1. Read the violation description
  2. Fix the code
  3. Re-run the gate
  4. Do not advance until PASS

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 5 — TESTING  (/test_order skill)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Load and follow the test_order skill.

- Retrieve the blast radius from Phase 1
- Build topological test execution order (leaf functions first)
- Run tests in that order, stopping at the first failure
- Fix failures and rerun from the top of the order
- Document any coverage gaps (symbols with no test)

Gate: all tests pass.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PHASE 6 — CODE REVIEW  (/code_review skill)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Load and follow the code_review skill.

- Annotate every changed symbol: caller count, domain, cross-domain exposure
- Produce graph diff summary (new/removed nodes and edges)
- Assign risk level (LOW / MEDIUM / HIGH) to each changed symbol
- Flag reviewer focus areas

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FACTORY RUN REPORT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
After all phases complete, print:

## Factory Run: $goal

**Status:** COMPLETE | PARTIAL | FAILED

| Phase | Status | Notes |
|-------|--------|-------|
| 1. Planning       | PASS | ... |
| 2. Arch Review    | PASS | ... |
| 3. Code Gen       | PASS | ... |
| 4. Quality Gate   | PASS | ... |
| 5. Testing        | PASS | ... |
| 6. Code Review    | PASS | ... |

**Files changed:** <list>
**Blast radius:**  <n> symbols affected
**Risk level:**    LOW / MEDIUM / HIGH
PROMPT
}

build_health_prompt() {
  local codebase="$1"
  cat <<PROMPT
You are Big Iron running in health monitoring mode.

Codebase: $codebase

Load the health_cron skill and run a full health check. Use the terminal tool
for all graph queries — do not read source files.

API calls can take up to 20 minutes on large codebases. Wait for each script
to exit before interpreting output. 0 results means the classifier found nothing
in that category, not that the script failed.

Step 1 — Full health gate:
  $SCRIPTS/graph_gate.sh health $codebase

Step 2 — Architecture validation:
  $SCRIPTS/graph_gate.sh arch $codebase

Step 3 — Identify the top 3 highest-risk symbols by blast radius.
  Use $SCRIPTS/graph_gate.sh impact $codebase <file:fn> for each candidate.
  Pick candidates based on the call graph (high in-degree or cross-domain).

Step 4 — Output the health report:

## Big Iron Health Report — $(date -u +%Y-%m-%d)

**Status:** HEALTHY | DEGRADED | CRITICAL

### Metrics
- Dead code candidates: <n>
- Circular dependencies: <n>
- Test coverage: <n>%
- Domains identified: <n>

### Top Risk Symbols
<symbol, blast radius, risk factors>

### Recommendations
<prioritized list — highest value items first>
PROMPT
}

build_improve_prompt() {
  local codebase="$1"
  cat <<PROMPT
You are Big Iron running in continuous improvement mode.

Codebase: $codebase

Your job: find the highest-value improvements and execute them autonomously.
Use the terminal tool for all graph queries. Graph first, files second.

API calls can take up to 20 minutes on large codebases. Wait for each script
to exit before interpreting output. 0 results means the classifier found nothing
in that category, not a script failure.

Step 1 — Health baseline (health_cron + guardrails skills):
  $SCRIPTS/graph_gate.sh health $codebase
  $SCRIPTS/graph_gate.sh arch $codebase

Step 2 — Identify and score refactor targets (refactor skill):
  Score each candidate:
    +2  circular dependency (must fix)
    +2  in-degree above guardrail threshold
    +1  dead code
    +1  dependency depth > 5
    -1  protected interface (higher risk)
    -1  cross-domain callers > 5 (higher blast radius)
  Work highest score first.

Step 3 — For each target in priority order:
  a. Phase 2 arch check on the proposed refactor
  b. Derive execution order via topological sort (leaf symbols first)
  c. Execute the refactor (codegen skill)
  d. Phase 4 quality gate — must PASS before moving to next symbol
  e. Phase 5 tests — must all pass

Step 4 — Dead code sweep:
  $SCRIPTS/graph_gate.sh quality $codebase
  Delete newly unreachable functions. Re-run quality gate.

Step 5 — Output improvement report with before/after metrics.
PROMPT
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_run() {
  local codebase="${1:-}" goal="${2:-}"
  if [[ -z "$codebase" || -z "$goal" ]]; then
    echo "Usage: factory run <codebase> \"<goal>\""
    exit 1
  fi
  local abs
  abs=$(require_codebase "$codebase")

  echo -e "  ${CYAN}mode${RESET}      run"
  echo -e "  ${CYAN}codebase${RESET}  $abs"
  echo -e "  ${CYAN}goal${RESET}      $goal"
  echo ""

  exec hermes chat \
    --yolo \
    --skills planning,arch_check,guardrails,codegen,quality_gates,test_order,code_review \
    -q "$(build_run_prompt "$abs" "$goal")"
}

cmd_health() {
  local codebase="${1:-}"
  if [[ -z "$codebase" ]]; then
    echo "Usage: factory health <codebase>"
    exit 1
  fi
  local abs
  abs=$(require_codebase "$codebase")

  echo -e "  ${CYAN}mode${RESET}      health"
  echo -e "  ${CYAN}codebase${RESET}  $abs"
  echo ""

  exec hermes chat \
    --yolo \
    --skills health_cron,guardrails \
    -q "$(build_health_prompt "$abs")"
}

cmd_improve() {
  local codebase="${1:-}"
  if [[ -z "$codebase" ]]; then
    echo "Usage: factory improve <codebase>"
    exit 1
  fi
  local abs
  abs=$(require_codebase "$codebase")

  echo -e "  ${CYAN}mode${RESET}      improve"
  echo -e "  ${CYAN}codebase${RESET}  $abs"
  echo ""

  exec hermes chat \
    --yolo \
    --skills health_cron,refactor,guardrails,arch_check,codegen,quality_gates,test_order \
    -q "$(build_improve_prompt "$abs")"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

require_env
banner

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  run)     cmd_run "$@" ;;
  health)  cmd_health "$@" ;;
  improve) cmd_improve "$@" ;;
  *)
    echo -e "  ${BOLD}Usage${RESET}"
    echo ""
    echo "    factory run <codebase> \"<goal>\"    Autonomous goal completion (phases 1-6)"
    echo "    factory health <codebase>           Health check + risk report"
    echo "    factory improve <codebase>          Continuous improvement pass"
    echo ""
    echo -e "  ${BOLD}Examples${RESET}"
    echo ""
    echo "    factory run ./demo \"add discount system to orders\""
    echo "    factory health ./demo"
    echo "    factory improve ./demo"
    echo ""
    exit 1
    ;;
esac
